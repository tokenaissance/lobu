# Claude Code Slack Application Configuration
# Copy this file to .env and fill in your values

# ===========================================
# SLACK CONFIGURATION (Required)
# ===========================================

# Bot User OAuth Token (starts with xoxb-)
# Get this from your Slack app's "OAuth & Permissions" page
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-Level Token (starts with xapp-) - Required for Socket Mode
# Get this from your Slack app's "Basic Information" page
SLACK_APP_TOKEN=xapp-your-app-token-here

# Signing Secret - Required for request verification
# Get this from your Slack app's "Basic Information" page  
SLACK_SIGNING_SECRET=your-signing-secret-here

# ===========================================
# SLACK APPLICATION SETTINGS
# ===========================================

# Bot User ID (optional, will auto-detect if not provided)
SLACK_BOT_USER_ID=U1234567890

# Trigger phrase for non-mention messages (default: @bot)
SLACK_TRIGGER_PHRASE=@claude

# Use HTTP mode instead of Socket Mode (default: false)
# Set to true if you need to receive events via HTTP instead of WebSocket
SLACK_HTTP_MODE=false

# Port for HTTP mode (default: 3000)
PORT=3000

# ===========================================
# PERMISSIONS AND ACCESS CONTROL
# ===========================================

# Allow direct messages (default: true)
SLACK_ALLOW_DIRECT_MESSAGES=true

# Allow private channels/groups (default: false)
SLACK_ALLOW_PRIVATE_CHANNELS=false

# Comma-separated list of allowed user IDs (optional)
# If set, only these users can trigger the bot
SLACK_ALLOWED_USERS=U1234567890,U0987654321

# Comma-separated list of blocked user IDs (optional)
SLACK_BLOCKED_USERS=

# Comma-separated list of allowed channel IDs (optional)
# If set, bot only responds in these channels
SLACK_ALLOWED_CHANNELS=C1234567890,C0987654321

# Comma-separated list of blocked channel IDs (optional)
SLACK_BLOCKED_CHANNELS=

# ===========================================
# CLAUDE CONFIGURATION (Required)
# ===========================================

# Anthropic API Key for Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Alternative: Claude Code OAuth Token (Recommended)
CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token-here

# ===========================================
# CLAUDE EXECUTION SETTINGS
# ===========================================

# Maximum number of conversation turns (default: 20)
MAX_TURNS=20

# Execution timeout in minutes (default: 10)
TIMEOUT_MINUTES=10

# Claude model to use (default: claude-3-5-sonnet-20241022)
MODEL=claude-3-5-sonnet-20241022

# Fallback model if primary model fails
FALLBACK_MODEL=claude-3-haiku-20240307

# System prompt for Claude (optional)
SYSTEM_PROMPT=

# Additional system prompt to append (optional)
APPEND_SYSTEM_PROMPT=

# Custom instructions for all interactions (optional)
CUSTOM_INSTRUCTIONS=

# ===========================================
# TOOL CONFIGURATION
# ===========================================

# Comma-separated list of additional allowed tools (optional)
ALLOWED_TOOLS=

# Comma-separated list of disallowed tools (optional)
DISALLOWED_TOOLS=

# ===========================================
# FEATURE FLAGS
# ===========================================

# Enable emoji status reactions on user messages (default: true)
ENABLE_STATUS_REACTIONS=true

# Enable real-time progress updates (default: true)
ENABLE_PROGRESS_UPDATES=true

# ===========================================
# ENVIRONMENT AND LOGGING
# ===========================================

# Node environment (development, production)
NODE_ENV=development

# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Worker idle cleanup time in minutes (default: 60)
# Deployments idle for this duration will be automatically cleaned up
WORKER_IDLE_CLEANUP_MINUTES=60

# ===========================================
# WORKER NETWORK ACCESS CONTROL
# ===========================================
# Workers run in isolated network and access internet via gateway's filtering proxy
# Control behavior through domain configuration:
#
# Empty/unset: Complete isolation (deny all) - SECURE DEFAULT
#   WORKER_ALLOWED_DOMAINS=
#   → Workers have NO internet access
#
# Unrestricted: Allow all domains
#   WORKER_ALLOWED_DOMAINS=*
#   → Workers can access any domain (NOT RECOMMENDED for production)
#
# Allowlist: Deny by default, allow only specific domains
#   WORKER_ALLOWED_DOMAINS=api.anthropic.com,.anthropic.com,github.com
#   → Workers can only access listed domains
#
# Blocklist: Allow all except specific domains (use with *)
#   WORKER_ALLOWED_DOMAINS=*
#   WORKER_DISALLOWED_DOMAINS=malicious.com,spam.org
#   → Workers can access everything except blocked domains
#
# Allowlist with exceptions: Allow specific domains but block some subdomains
#   WORKER_ALLOWED_DOMAINS=.example.com
#   WORKER_DISALLOWED_DOMAINS=untrusted.example.com
#   → Allow *.example.com except untrusted.example.com

# Comma-separated list of allowed domains
# Domain format:
#   - api.anthropic.com         (exact domain)
#   - .anthropic.com            (wildcard: *.anthropic.com)
#   - *                         (unrestricted - allow all)
#
# Common domains for AI/dev workflows:
#   - api.anthropic.com,.anthropic.com              (Claude API)
#   - registry.npmjs.org,.npmjs.org                 (npm packages)
#   - github.com,.github.com,.githubusercontent.com (Git/GitHub)
#   - pypi.org,files.pythonhosted.org              (Python packages)
#   - cdn.jsdelivr.net,unpkg.com                    (CDN packages)
WORKER_ALLOWED_DOMAINS=api.anthropic.com,.anthropic.com,registry.npmjs.org,.npmjs.org,github.com,.github.com,.githubusercontent.com

# Comma-separated list of explicitly disallowed domains (optional)
# These domains will be blocked even if they match an allowed pattern
WORKER_DISALLOWED_DOMAINS=

# ===========================================
# QA TESTING CONFIGURATION (Optional)
# ===========================================

# QA Bot Token for testing (./test-bot.js)
# This should be the token for your QA/test bot
QA_SLACK_BOT_TOKEN=xoxb-your-qa-bot-token-here

# Target bot username for testing
# This should be the username/ID of the bot you want to test
QA_TARGET_BOT_USERNAME=your-target-bot-username-here

# ===========================================
# ADVANCED CONFIGURATION
# ===========================================

# Public gateway URL for OAuth callbacks (required for MCP OAuth)
# This should be the publicly accessible URL of your gateway
LOBU_PUBLIC_GATEWAY_URL=https://your-domain.com

# Socket Mode Health Monitoring
# Detects zombie WebSocket connections and triggers automatic restart
# Useful for recovering from network issues after laptop sleep/wake

# How often to check for zombie connection in milliseconds (default: 300000 = 5 min)
SOCKET_HEALTH_CHECK_INTERVAL_MS=300000

# Consider connection stale if no Socket Mode events for this long in milliseconds (default: 900000 = 15 min)
# Socket Mode sends internal heartbeats every ~30-60s, so 15 min without ANY events indicates a zombie connection
SOCKET_STALE_THRESHOLD_MS=900000

# Protect active workers from restart (default: true)
# If true, delays restart when workers are actively processing messages
SOCKET_PROTECT_ACTIVE_WORKERS=true

# MCP configuration file path or URL (optional)
# Can be a local file path or HTTP(S) URL
# File should contain MCP server configurations with OAuth settings
LOBU_MCP_SERVERS_FILE=/path/to/mcp-servers.json
LOBU_MCP_SERVERS_URL=https://example.com/mcp-servers.json

# Custom MCP configuration path (optional, deprecated - use LOBU_MCP_SERVERS_FILE)
MCP_CONFIG_PATH=

# Custom environment variables for Claude execution (optional)
# Format: KEY1: value1\nKEY2: value2
CLAUDE_ENV=

# ===========================================
# EXAMPLES AND HELP
# ===========================================

# Example allowed tools:
# ALLOWED_TOOLS=WebSearch,WebFetch

# Example disallowed tools:
# DISALLOWED_TOOLS=Bash

# Example custom instructions:
# CUSTOM_INSTRUCTIONS=Always explain your reasoning and provide code examples when relevant.

# Example Claude environment variables:
# CLAUDE_ENV=DEBUG: true\nVERBOSE: true

# Example MCP server configuration (mcp-servers.json):
# Option A - Full OAuth2 (Recommended):
# {
#   "mcpServers": {
#     "github": {
#       "url": "https://github-mcp.example.com",
#       "oauth": {
#         "authUrl": "https://github.com/login/oauth/authorize",
#         "tokenUrl": "https://github.com/login/oauth/access_token",
#         "clientId": "YOUR_GITHUB_CLIENT_ID",
#         "clientSecretEnv": "GITHUB_CLIENT_SECRET",
#         "scopes": ["repo", "read:user"]
#       }
#     }
#   }
# }
#
# Option B - Simple login URL:
# {
#   "mcpServers": {
#     "custom": {
#       "url": "https://custom-mcp.example.com",
#       "loginUrl": "https://custom-mcp.example.com/oauth/authorize?client_id=YOUR_ID"
#     }
#   }
# }

# OAuth client secrets (referenced by clientSecretEnv in MCP config)
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===========================================
# DOCKER HUB CONFIGURATION (For Deployment)
# ===========================================

# Docker Hub username for pushing images
DOCKER_USERNAME=your-dockerhub-username

# Docker Hub personal access token (recommended over password)
# Create at: https://hub.docker.com/settings/security
DOCKER_PASSWORD=your-dockerhub-access-token

# ===========================================
# GETTING STARTED
# ===========================================

# 1. Create a Slack app at https://api.slack.com/apps
# 2. Enable Socket Mode and generate an App-Level Token
# 3. Add the bot to your workspace and copy the Bot User OAuth Token
# 4. Copy the Signing Secret from Basic Information
# 5. Fill in the required values above
# 6. Run: bun run dev:slack