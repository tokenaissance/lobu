# Global ignores to speed up Docker context and builds
.git
.gitignore
.DS_Store
node_modules
**/node_modules
**/dist
**/.turbo
**/.cache
**/.next
**/coverage
**/.bun

# Local volumes and workspaces
workspaces/
workspaces/**

# Editor and OS files
.vscode
.idea
*.swp
*.swo

# Env and secrets (Compose will mount .env at runtime)
.env
.env.*

# Logs and tmp
logs/
*.log
tmp/
**/.pytest_cache

# Claude local data
.claude/sessions/
.claude/cache/
