{
  "name": "@lobu/cli",
  "version": "4.2.0",
  "description": "CLI for deploying and managing AI agents on Lobu",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lobu": "bin/lobu.js"
  },
  "scripts": {
    "build": "tsc && node scripts/build.cjs",
    "dev": "tsc --watch"
  },
  "keywords": [
    "lobu",
    "ai",
    "agent",
    "deployment",
    "cli"
  ],
  "author": "Burak Emre",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lobu-ai/lobu.git",
    "directory": "packages/cli"
  },
  "dependencies": {
    "@lobu/core": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.2.14",
    "marked": "^17.0.4",
    "marked-terminal": "^7.3.0",
    "open": "^10.1.0",
    "ora": "^8.0.1",
    "smol-toml": "^1.3.1",
    "yaml": "^2.7.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
