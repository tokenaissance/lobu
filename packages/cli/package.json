{
  "name": "@lobu/cli",
  "version": "5.0.0",
  "description": "CLI for deploying and managing AI agents on Lobu",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lobu": "bin/lobu.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc && node scripts/build.cjs",
    "dev": "tsc --watch"
  },
  "keywords": [
    "lobu",
    "ai",
    "agent",
    "deployment",
    "cli"
  ],
  "author": "Burak Emre",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lobu-ai/lobu.git",
    "directory": "packages/cli"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-bedrock": "^3.1028.0",
    "@aws-sdk/client-secrets-manager": "^3.1028.0",
    "@chat-adapter/discord": "4.26.0",
    "@chat-adapter/gchat": "4.26.0",
    "@chat-adapter/slack": "4.26.0",
    "@chat-adapter/teams": "4.26.0",
    "@chat-adapter/telegram": "4.26.0",
    "@chat-adapter/whatsapp": "4.26.0",
    "@hono/node-server": "^1.19.9",
