# lobu.toml — Agent configuration
# Docs: https://lobu.ai/docs/getting-started
#
# Agent identity lives in markdown files:
#   IDENTITY.md  — Who the agent is (persona, name, tone)
#   SOUL.md      — Behavior rules & instructions
#   USER.md      — User-specific context (timezone, preferences)
#   skills/*.md  — Custom capabilities (auto-discovered)

[agent]
name = "{{AGENT_NAME}}"
description = "{{AGENT_DESCRIPTION}}"

# LLM providers (order = priority)
[[providers]]
id = "groq"
model = "llama-3.3-70b-versatile"

# Skills from the registry (run `lobu skills list` to see available)
[skills]
enabled = ["github"]

# Custom MCP servers
# [skills.mcp.my-server]
# url = "https://mcp.example.com/sse"

# [skills.mcp.playwright]
# command = "npx"
# args = ["-y", "@playwright/mcp"]

# Network sandbox
[network]
allowed = ["api.github.com", "registry.npmjs.org", "pypi.org"]

# Worker config
# [worker]
# nix_packages = ["python311", "ffmpeg"]
# timeout_minutes = 5

# Platforms — declare which messaging connections to enable.
# Credentials are configured via the settings page after startup.

# [platforms.telegram]
# mode = "auto"

# [platforms.slack]

# [platforms.discord]

# [platforms.whatsapp]

# [platforms.teams]
