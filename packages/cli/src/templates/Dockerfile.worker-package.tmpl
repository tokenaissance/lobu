# Advanced Mode: Bring Your Own Base Image
# This Dockerfile installs @lobu/worker as a package instead of extending our base image.
# You have full control over the base OS, system packages, and security configuration.

# STEP 1: Choose your base image
# Examples:
#   - FROM node:20-alpine          (small, fast)
#   - FROM ubuntu:22.04            (most compatible)
#   - FROM oven/bun:1.2.9-alpine   (best performance)
#   - FROM your-company/golden-image:latest  (compliance)

FROM node:20-alpine

# STEP 2: Install required system dependencies
# The worker requires: git, docker-cli (optional), python3 (optional), curl
RUN apk add --no-cache \
    git \
    curl \
    docker-cli \
    python3 \
    py3-pip

# STEP 3: Install Claude CLI (required for AI interactions)
RUN curl -L https://claude.ai/install.sh | sh

# STEP 4: Install Lobu worker package
RUN npm install -g @lobu/worker@latest

# === CUSTOMIZE BELOW THIS LINE ===

# Example: Add system packages
# RUN apk add --no-cache postgresql-client redis

# Example: Add Python packages
# RUN pip3 install --break-system-packages \
#     pandas \
#     matplotlib \
#     requests

# Example: Add Node.js packages globally
# RUN npm install -g \
#     @octokit/rest \
#     typescript

# Example: Copy custom scripts
# COPY ./scripts /workspace/scripts
# RUN chmod +x /workspace/scripts/*.sh

# Set working directory
WORKDIR /workspace

# Run the worker
CMD ["lobu-worker"]
