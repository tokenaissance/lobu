{
  "name": "owletto",
  "version": "4.0.1",
  "description": "Unified CLI for Lobu memory — dev, deploy, and manage from one command",
  "type": "module",
  "bin": {
    "owletto": "./dist/bin.js"
  },
  "exports": {
    ".": "./dist/bin.js",
    "./schema": "./dist/lib/schema.js"
  },
  "files": [
    "dist",
    "runtime"
  ],
  "scripts": {
    "build": "tsup && node ./scripts/prepare-runtime.mjs",
    "clean": "rm -rf dist runtime",
    "dev": "tsx src/bin.ts",
    "runtime:prepare": "node ./scripts/prepare-runtime.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.3",
    "@electric-sql/pglite-socket": "^0.1.3",
    "@hono/node-server": "^1.13.7",
    "@jitl/quickjs-ng-wasmfile-release-asyncify": "0.31.0",
    "@lobu/core": "workspace:*",
    "@lobu/owletto-sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@polyglot-sql/sdk": "^0.1.13",
    "@sebastianwessel/quickjs": "^3.0.1",
    "@sentry/cli": "^2.58.2",
    "@sentry/node": "^9.0.0",
    "@sinclair/typebox": "^0.34.41",
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-auth": "^1.4.10",
    "citty": "^0.1.6",
    "cron-parser": "^5.5.0",
    "cycletls": "^2.0.5",
    "dotenv": "^16.4.5",
    "esbuild": "^0.27.0",
    "handlebars": "^4.7.9",
    "hono": "^4.10.4",
    "hono-pino": "^0.10.3",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "playwright": "npm:patchright@^1.57.0",
    "postgres": "^3.4.7",
    "resend": "^6.6.0",
    "smol-toml": "^1.3.1",
    "tsx": "^4.19.2",
    "turndown": "^7.2.2",
    "vite": "^6.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@types/node": "^22.10.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "BUSL-1.1",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lobu-ai/owletto.git",
    "directory": "packages/cli"
  }
}
