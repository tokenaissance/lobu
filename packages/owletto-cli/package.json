{
  "name": "owletto",
  "version": "6.0.0",
  "description": "Unified CLI for Lobu memory — dev, deploy, and manage from one command",
  "type": "module",
  "bin": {
    "owletto": "./dist/bin.js"
  },
  "exports": {
    ".": "./dist/bin.js",
    "./schema": "./dist/lib/schema.js"
  },
  "files": [
    "dist",
    "runtime"
  ],
  "scripts": {
    "build": "tsup && node ./scripts/copy-bundled-skills.mjs && node ./scripts/prepare-runtime.mjs",
    "clean": "rm -rf dist runtime",
    "dev": "tsx src/bin.ts",
    "runtime:prepare": "node ./scripts/prepare-runtime.mjs",
    "test:smoke": "SMOKE=1 bun test src/__tests__/smoke",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lobu/core": "workspace:*",
    "@lobu/owletto-sdk": "workspace:*",
    "citty": "^0.1.6",
    "playwright": "npm:patchright@^1.57.0",
    "smol-toml": "^1.3.1",
    "tsx": "^4.19.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@types/node": "^22.10.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "BUSL-1.1",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lobu-ai/owletto.git",
    "directory": "packages/cli"
  }
}
