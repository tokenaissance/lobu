---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../globals.css";
import { Footer } from "../components/Footer";
import { PricingSection } from "../components/PricingSection";
import { Nav } from "../components/Nav";
---

<BaseLayout
  title="Pricing - Lobu"
  description="Lobu is open source. Self-host for free or get expert help deploying agents for your organization."
>
  <div
    class="min-h-screen grid-lines"
    style={{
      backgroundColor: "var(--color-page-bg)",
      "--grid-max-w": "60rem",
    }}
  >
    <Nav currentPath={Astro.url.pathname} />
    <main class="relative z-[1]">
      <PricingSection client:load />
    </main>
    <Footer />
  </div>
</BaseLayout>
