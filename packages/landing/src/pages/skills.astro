---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../globals.css";
import { Footer } from "../components/Footer";
import { Nav } from "../components/Nav";
import { SkillsSection } from "../components/SkillsSection";
import { getSurfaceHeroCopy } from "../use-case-showcases";
---

<BaseLayout title="Skills - Build and bundle agent skills" description="Develop skills with integrations, MCP servers, network policies, and system packages — all bundled into one installable unit.">
  <div
    class="min-h-screen grid-lines"
    style={{
      backgroundColor: "var(--color-page-bg)",
      "--grid-max-w": "72rem",
    }}
  >
    <Nav currentPath={Astro.url.pathname} />
    <main class="relative z-[1]">
      <SkillsSection
        client:load
        linkTabsToCampaigns
        heroCopy={getSurfaceHeroCopy("skills")}
      />
    </main>
    <Footer />
  </div>
</BaseLayout>
