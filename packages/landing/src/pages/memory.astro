---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../globals.css";
import { Footer } from "../components/Footer";
import { MemorySection } from "../components/MemorySection";
import { Nav } from "../components/Nav";
import { getLatestPosts } from "../latest-posts";

const latestPosts = await getLatestPosts();
---

<BaseLayout
  title="Memory - Owletto organizational memory for agents"
  description="Owletto gives Lobu multi-tenant organizational memory with typed entities, connectors, watchers, and managed OAuth."
>
  <div
    class="min-h-screen grid-lines"
    style={{
      backgroundColor: "var(--color-page-bg)",
      "--grid-max-w": "72rem",
    }}
  >
    <Nav currentPath={Astro.url.pathname} />
    <main class="relative z-[1]">
      <MemorySection client:load linkTabsToPages latestPosts={latestPosts} />
    </main>
    <Footer />
  </div>
</BaseLayout>
