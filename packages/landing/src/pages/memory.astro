---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../globals.css";
import { Footer } from "../components/Footer";
import { MemorySection } from "../components/MemorySection";
import { Nav } from "../components/Nav";
import { getLatestPosts } from "../latest-posts";
import { getSurfaceHeroCopy } from "../use-case-showcases";

const latestPosts = await getLatestPosts();
---

<BaseLayout
  title="Memory - Owletto organizational memory for agents"
  description="Owletto provides multi-tenant organizational memory with typed entities, connectors, watchers, and managed OAuth. Lobu can optionally use it as its memory backend."
>
  <div
    class="min-h-screen grid-lines"
    style={{
      backgroundColor: "var(--color-page-bg)",
      "--grid-max-w": "72rem",
    }}
  >
    <Nav currentPath={Astro.url.pathname} />
    <main class="relative z-[1]">
      <MemorySection
        client:load
        linkTabsToPages
        latestPosts={latestPosts}
        heroCopy={getSurfaceHeroCopy("memory")}
      />
    </main>
    <Footer />
  </div>
</BaseLayout>
