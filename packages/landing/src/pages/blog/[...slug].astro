---
import { getCollection, render } from "astro:content";
import { Footer } from "../../components/Footer";
import { Nav } from "../../components/Nav";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../globals.css";

export async function getStaticPaths() {
  const isProduction = import.meta.env.PROD;
  const posts = await getCollection("blog", ({ data }) =>
    isProduction ? !data.draft : true
  );
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFormatted = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const dateISO = post.data.date.toISOString();
const canonicalURL = new URL(`/blog/${post.id}`, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: dateISO,
  author: {
    "@type": "Person",
    name: post.data.author,
    ...(post.data.authorUrl && { url: post.data.authorUrl }),
  },
  url: canonicalURL.toString(),
  publisher: {
    "@type": "Organization",
    name: "Lobu",
    url: "https://lobu.ai",
    logo: { "@type": "ImageObject", url: "https://lobu.ai/lobster-icon.png" },
  },
  image: "https://lobu.ai/lobster-icon.png",
  keywords: post.data.tags,
};
---

<BaseLayout
  title={`${post.data.title} - Lobu Blog`}
  description={post.data.description}
  ogType="article"
  article={{ publishedTime: dateISO, author: post.data.author, tags: post.data.tags }}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="min-h-screen grid-lines" style={{ backgroundColor: "var(--color-page-bg)" }}>
    <Nav currentPath={Astro.url.pathname} />
    <main class="relative z-[1]">
      {/* Hero */}
      <header class="pt-28 pb-16 px-6 text-center">
        <a
          href="/blog"
          class="inline-block text-xs font-medium tracking-wider uppercase mb-8"
          style={{ color: "var(--color-page-text-muted)" }}
        >
          Blog
        </a>
        <h1
          class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-[1.1] max-w-3xl mx-auto"
          style={{ color: "var(--color-page-text)" }}
        >
          {post.data.title}
        </h1>

        {/* Author */}
        <div class="flex items-center justify-center gap-3 mt-8">
          {post.data.authorAvatar && (
            <img
              src={post.data.authorAvatar}
              alt={post.data.author}
              class="w-7 h-7 rounded-full"
              loading="lazy"
            />
          )}
          {post.data.authorUrl ? (
            <a
              href={post.data.authorUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm transition-colors hover:opacity-80"
              style={{ color: "var(--color-page-text)" }}
            >
              {post.data.author}
            </a>
          ) : (
            <span class="text-sm" style={{ color: "var(--color-page-text)" }}>
              {post.data.author}
            </span>
          )}
        </div>
      </header>

      {/* Metadata bar */}
      <div class="section-divider" />
      <div class="max-w-3xl mx-auto px-6 flex items-center justify-between py-4">
        <div class="flex items-center gap-4">
          {post.data.tags.length > 0 && (
            <div class="flex gap-2">
              {post.data.tags.map((tag: string) => (
                <span
                  class="text-[11px] font-medium px-2.5 py-1 rounded-full"
                  style={{
                    backgroundColor: "var(--color-page-surface-dim)",
                    color: "var(--color-page-text-muted)",
                    border: "1px solid var(--color-page-border)",
                  }}
                >
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
        <time
          class="text-sm"
          datetime={dateISO}
          style={{ color: "var(--color-page-text-muted)" }}
        >
          {dateFormatted}
        </time>
      </div>
      <div class="section-divider" />

      {/* Content */}
      <article class="max-w-3xl mx-auto px-6 py-16">
        <div class="blog-prose max-w-none">
          <Content />
        </div>
      </article>

      <div class="section-divider" />

      {/* Bottom nav */}
      <div class="max-w-3xl mx-auto px-6 py-10 flex items-center justify-between">
        <a
          href="/blog"
          class="text-sm transition-colors hover:opacity-80"
          style={{ color: "var(--color-page-text-muted)" }}
        >
          &larr; View all blog posts
        </a>
      </div>
    </main>
    <Footer />
  </div>
</BaseLayout>
