---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import "../../../globals.css";
import { Footer } from "../../../components/Footer";
import { MemorySection } from "../../../components/MemorySection";
import { Nav } from "../../../components/Nav";
import {
  getLandingUseCaseShowcase,
  landingUseCaseShowcases,
} from "../../../use-case-showcases";
import { getLatestPosts } from "../../../latest-posts";

export function getStaticPaths() {
  return landingUseCaseShowcases.map((useCase) => ({
    params: { useCase: useCase.id },
    props: { useCaseId: useCase.id },
  }));
}

const { useCaseId } = Astro.props;
const showcase = getLandingUseCaseShowcase(useCaseId);
const latestPosts = await getLatestPosts();
---

<BaseLayout
  title={`Memory for ${showcase.label} - Lobu`}
  description={showcase.memory.description}
>
  <div
    class="min-h-screen grid-lines"
    style={{
      backgroundColor: "var(--color-page-bg)",
      "--grid-max-w": "72rem",
    }}
  >
    <Nav currentPath={Astro.url.pathname} />
    <main class="relative z-[1]">
      <MemorySection
        client:load
        defaultUseCaseId={showcase.id}
        linkTabsToPages
        latestPosts={latestPosts}
      />
    </main>
    <Footer />
  </div>
</BaseLayout>
