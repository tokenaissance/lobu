---
import type { ConnectFromClientId } from "../../connect-from-config";
import { landingUseCaseOptions } from "../../use-case-showcases";

const { clientId } = Astro.props as { clientId: ConnectFromClientId };
---

<div class="flex flex-wrap gap-2 mt-4">
  {landingUseCaseOptions.map((useCase) => (
    <a
      href={`/connect-from/${clientId}/for/${useCase.id}/`}
      class="inline-flex items-center rounded-full px-3 py-1.5 text-sm font-medium transition-colors hover:opacity-80"
      style={{
        color: "var(--color-page-text)",
        backgroundColor: "var(--color-page-surface)",
        border: "1px solid var(--color-page-border-active)",
      }}
    >
      {useCase.label}
    </a>
  ))}
</div>
