---
import type { ConnectFromClientId } from "../../connect-from-config";
import { landingUseCaseOptions } from "../../use-case-showcases";

const { clientId, activeUseCaseId } = Astro.props as {
  clientId: ConnectFromClientId;
  activeUseCaseId?: string;
};
---

<div class="flex flex-wrap gap-2 mt-4">
  {landingUseCaseOptions.map((useCase) => {
    const isActive = useCase.id === activeUseCaseId;
    return (
      <a
        href={`/connect-from/${clientId}/for/${useCase.id}/`}
        aria-current={isActive ? "page" : undefined}
        class="inline-flex items-center rounded-full px-3 py-1.5 text-sm font-medium transition-colors hover:opacity-80"
        style={{
          color: isActive
            ? "var(--color-page-bg)"
            : "var(--color-page-text)",
          backgroundColor: isActive
            ? "var(--color-page-text)"
            : "var(--color-page-surface)",
          border: "1px solid var(--color-page-border-active)",
        }}
      >
        {useCase.label}
      </a>
    );
  })}
</div>
