{
  "name": "@lobu/owletto-backend",
  "version": "1.6.0",
  "private": true,
  "license": "BUSL-1.1",
  "type": "module",
  "description": "Lobu memory backend — Hono HTTP server, MCP handler, REST API, embedded @lobu/gateway",
  "scripts": {
    "dev": "tsx watch --ignore=../owletto-web/** --ignore=../../node_modules/** src/server.ts",
    "start": "tsx src/server.ts",
    "test": "vitest",
    "test:pglite": "OWLETTO_TEST_BACKEND=pglite vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write src",
    "check": "biome check --write src"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@lobu/core": "workspace:*",
    "@lobu/gateway": "workspace:*",
    "@lobu/owletto-sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@polyglot-sql/sdk": "^0.1.13",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@sentry/node": "^9.0.0",
    "@sinclair/typebox": "^0.34.41",
    "@slack/socket-mode": "^2.0.6",
    "@types/pg": "^8.16.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-auth": "^1.4.10",
    "cron-parser": "^5.5.0",
    "handlebars": "^4.7.9",
    "hono": "^4.10.4",
    "hono-pino": "^0.10.3",
    "kysely": "^0.28.0",
    "kysely-postgres-js": "^2.0.0",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "postgres": "^3.4.7",
    "react": "^19.2.5",
    "resend": "^6.6.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.3",
    "@electric-sql/pglite-socket": "^0.1.3",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^2.1.8",
    "dotenv": "^16.4.5",
    "esbuild": "^0.27.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "isolated-vm": "^6.1.2"
  }
}
