{
  "name": "@lobu/gateway",
  "version": "3.4.0",
  "license": "Apache-2.0",
  "description": "Lobu SDK — embed AI agents with platform adapters, worker orchestration, and MCP proxy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lobu-ai/lobu.git",
    "directory": "packages/gateway"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./dist/connections": {
      "types": "./dist/connections/index.d.ts",
      "import": "./dist/connections/index.js",
      "require": "./dist/connections/index.js"
    },
    "./dist/api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js",
      "require": "./dist/api/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "DEPLOYMENT_MODE=docker bun --watch src/index.ts -- --env ../../.env",
    "start": "cd ../core && bun run build && cd ../gateway && bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.1028.0",
    "@aws-sdk/client-secrets-manager": "^3.1028.0",
    "@chat-adapter/discord": "4.26.0",
    "@chat-adapter/gchat": "4.26.0",
    "@chat-adapter/slack": "4.26.0",
    "@chat-adapter/state-ioredis": "4.26.0",
    "@chat-adapter/teams": "4.26.0",
    "@chat-adapter/telegram": "4.26.0",
    "@chat-adapter/whatsapp": "4.26.0",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^1.2.1",
    "@kubernetes/client-node": "0.21.0",
    "@lobu/core": "workspace:*",
    "@mariozechner/pi-ai": "^0.51.6",
    "@scalar/hono-api-reference": "^0.9.39",
    "@sentry/node": "^10.19.0",
    "bullmq": "^5.31.5",
    "chat": "^4.26.0",
    "commander": "^14.0.1",
    "cron-parser": "^5.5.0",
    "dockerode": "^4.0.7",
    "dotenv": "^17.2.1",
    "hono": "^4.11.7",
    "ioredis": "^5.4.1",
    "smol-toml": "^1.3.1",
    "yaml": "^2.7.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.29",
    "@types/node": "^20.0.0",
    "typescript": "^5.8.3"
  }
}
