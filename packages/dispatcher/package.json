{
  "name": "@peerbot/dispatcher",
  "version": "1.0.0",
  "private": true,
  "description": "Slack dispatcher service that routes messages to Kubernetes worker Jobs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/index.ts",
    "start": "cd ../shared && bun run build && cd ../dispatcher && bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@peerbot/shared": "workspace:*",
    "axios": "^1.7.2",
    "express": "^4.19.2",
    "marked": "^12.0.0",
    "pg-boss": "^10.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/marked": "^6.0.0",
    "typescript": "^5.8.3"
  }
}
