{
  "name": "@lobu/core",
  "version": "4.2.0",
  "license": "Apache-2.0",
  "description": "Core types and utilities for Lobu agent platform",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lobu-ai/lobu.git",
    "directory": "packages/core"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/__tests__/fixtures/index.d.ts",
      "bun": "./src/__tests__/fixtures/index.ts",
      "import": "./dist/__tests__/fixtures/index.js",
      "require": "./dist/__tests__/fixtures/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-node": "^1.30.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@sentry/node": "^10.23.0",
    "ioredis": "^5.4.1",
    "winston": "^3.17.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bun": "1.2.11",
    "@types/node": "^20.0.0",
    "typescript": "^5.8.3"
  }
}
