#!/bin/sh

# Check code formatting, linting and fix issues before push
echo "Running Biome checks (format, lint, organize imports)..."

# Use biome check which includes formatting, linting, and import organization
if ! bun run check; then
    echo "Biome found issues. Attempting to fix them automatically..."
    bun run check:fix

    # Check if there are any staged changes after fixing
    if git diff --name-only --exit-code; then
        echo "All issues have been automatically fixed."
    else
        echo ""
        echo "ERROR: Code has been fixed but changes need to be committed!"
        echo "Please commit the fixed files and try again."
        echo ""
        echo "The following files were modified:"
        git diff --name-only
        echo ""
        exit 1
    fi
else
    echo "All Biome checks passed."
fi

# Run type checking
echo "Running type checking..."
if ! bun run typecheck; then
    echo "Type checking failed. Please fix the type errors and try again."
    exit 1
else
    echo "Type checking passed."
fi

# Run tests
echo "Running tests..."
if ! bun run test; then
    echo "Tests failed. Please fix the failing tests and try again."
    exit 1
else
    echo "All tests passed."
fi

exit 0
