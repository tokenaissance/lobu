        "includeAll": false,
        "label": "Loki Datasource",
        "multi": false,
        "name": "lokiDatasource",
        "options": [],
        "query": "loki",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {
          "selected": false,
          "text": "tr-",
          "value": "tr-"
