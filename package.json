{
  "name": "@peerbot/cli",
  "version": "1.0.6",
  "bin": {
    "peerbot": "./bin/peerbot"
  },
  "workspaces": [
    "packages/dispatcher",
    "packages/orchestrator",
    "packages/shared",
    "packages/worker"
  ],
  "scripts": {
    "build": "cd packages/shared && bun run build && cd ../dispatcher && bun run build && cd ../orchestrator && bun run build && cd ../worker && bun run build && cd ../..",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "install-hooks": "bun run scripts/install-hooks.sh",
    "prepare": "husky || true",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "dev:slack": "bun run src/entrypoints/slack-main.ts",
    "start:slack": "NODE_ENV=production bun run src/entrypoints/slack-main.ts",
    "build:slack": "bun build src/entrypoints/slack-main.ts --outdir dist --target bun",
    "build:packages": "bun run --filter='packages/*' build",
    "test:packages": "bun run --filter='packages/*' test",
    "typecheck:packages": "bun run --filter='packages/*' typecheck",
    "dev:dispatcher": "bun run packages/dispatcher/src/index.ts",
    "dev:worker": "bun run packages/worker/src/index.ts",
    "docker:build": "docker build -f docker/dispatcher.Dockerfile -t claude-dispatcher . && docker build -f docker/worker.Dockerfile -t claude-worker .",
    "k8s:deploy": "helm upgrade --install peerbot charts/peerbot --dependency-update",
    "k8s:uninstall": "helm uninstall peerbot"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.14.0",
    "@kubernetes/client-node": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "@octokit/graphql": "^8.2.2",
    "@octokit/rest": "^21.1.1",
    "@octokit/webhooks-types": "^7.6.1",
    "@sentry/node": "^10.6.0",
    "@slack/bolt": "^3.19.0",
    "@slack/web-api": "^7.6.0",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.11.5",
    "winston": "^3.17.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@types/bun": "1.2.11",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.12",
    "dotenv": "^17.2.1",
    "husky": "^9.1.7",
    "typescript": "^5.8.3"
  }
}
