{
  "name": "create-peerbot",
  "version": "2.3.0",
  "workspaces": [
    "packages/cli",
    "packages/gateway",
    "packages/github",
    "packages/core",
    "packages/worker"
  ],
  "scripts": {
    "build": "cd packages/core && bun run build && cd ../gateway && bun run build && cd ../worker && bun run build && cd ../..",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "install-hooks": "bun run scripts/install-hooks.sh",
    "prepare": "husky || true",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "jscpd": "bunx jscpd --pattern \"packages/**/*.ts\" --reporters \"console\" --ignore \"**/node_modules/**,**/dist/**,**/coverage/**,**/.bun/**,**/.turbo/**,workspaces/**,charts/**,integration-tests/**,examples/**,bin/**,**/__tests__/**,**/__mocks__/**,**/*.d.ts\"",
    "depcruise": "bunx --bun depcruise --config dependency-cruiser.config.cjs packages",
    "dev:slack": "bun run src/entrypoints/slack-main.ts",
    "build:packages": "bun run --filter='packages/*' build",
    "test:packages": "bun run --filter='packages/*' test",
    "typecheck:packages": "bun run --filter='packages/*' typecheck",
    "knip": "bunx knip",
    "gitleaks": "docker run --rm -v $(pwd):/repo -w /repo zricethezav/gitleaks:latest detect --source=/repo --no-git --redact --config=/repo/gitleaks.toml",
    "dev:gateway": "bun run packages/gateway/src/index.ts",
    "dev:worker": "bun run packages/worker/src/index.ts",
    "docker:build": "docker build -f docker/gateway.Dockerfile -t claude-gateway . && docker build -f docker/worker.Dockerfile -t claude-worker .",
    "k8s:deploy": "helm upgrade --install peerbot charts/peerbot --dependency-update",
    "k8s:uninstall": "helm uninstall peerbot"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.14.0",
    "@kubernetes/client-node": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "@octokit/rest": "^21.1.1",
    "@sentry/node": "^10.6.0",
    "@slack/bolt": "^4.5.0",
    "@slack/web-api": "^7.11.0",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "node-fetch": "^3.3.2",
    "winston": "^3.17.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@types/bun": "1.2.11",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.12",
    "dependency-cruiser": "^17.1.0",
    "dotenv": "^17.2.1",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "knip": "^5.66.3",
    "typescript": "^5.8.3"
  }
}
