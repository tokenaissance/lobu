            "clientId": "${env:SENTRY_CLIENT_ID}",
            "clientSecret": "${env:SENTRY_CLIENT_SECRET}"
          },
          "scopesConfig": {
            "default": ["org:read", "project:read", "event:read"],
            "available": [
              "org:read",
              "org:write",
              "project:read",
              "project:write",
              "project:releases",
              "team:read",
              "team:write",
              "member:read",
              "event:read",
              "event:write"
            ]
          },
          "apiDomains": ["sentry.io"]
        }
