{
  "skills": [
    {
      "id": "google-workspace",
      "name": "Google Workspace",
      "description": "Gmail, Calendar, Drive integration",
      "integrations": [
        {
          "id": "google",
          "label": "Google",
          "authType": "oauth",
          "oauth": {
            "authUrl": "https://accounts.google.com/o/oauth2/v2/auth",
            "tokenUrl": "https://oauth2.googleapis.com/token",
            "clientId": "${env:GOOGLE_CLIENT_ID}",
            "clientSecret": "${env:GOOGLE_CLIENT_SECRET}",
            "incrementalAuth": true
          },
          "scopesConfig": {
            "default": ["openid", "profile", "email"],
            "available": [
              "https://www.googleapis.com/auth/gmail.readonly",
              "https://www.googleapis.com/auth/gmail.send",
              "https://www.googleapis.com/auth/calendar.readonly",
              "https://www.googleapis.com/auth/calendar.events",
              "https://www.googleapis.com/auth/drive.readonly"
            ]
          },
          "apiDomains": [
            "gmail.googleapis.com",
            "www.googleapis.com",
            "calendar.googleapis.com"
          ]
        }
      ]
    },
    {
      "id": "github",
      "name": "GitHub",
      "description": "Repos, issues, pull requests, and code access",
      "integrations": [
        {
          "id": "github",
          "label": "GitHub",
          "authType": "oauth",
          "oauth": {
            "authUrl": "https://github.com/login/oauth/authorize",
            "tokenUrl": "https://github.com/login/oauth/access_token",
            "clientId": "${env:GITHUB_CLIENT_ID}",
            "clientSecret": "${env:GITHUB_CLIENT_SECRET}"
          },
          "scopesConfig": {
            "default": ["read:user", "user:email"],
            "available": [
              "repo",
              "read:org",
              "read:project",
              "gist",
              "notifications"
            ]
          },
          "apiDomains": ["api.github.com", "raw.githubusercontent.com"]
        }
      ]
    },
    {
      "id": "microsoft-365",
      "name": "Microsoft 365",
      "description": "Outlook, OneDrive, and Teams integration",
      "integrations": [
        {
          "id": "microsoft",
          "label": "Microsoft",
          "authType": "oauth",
          "oauth": {
            "authUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
            "tokenUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
            "clientId": "${env:MICROSOFT_CLIENT_ID}",
            "clientSecret": "${env:MICROSOFT_CLIENT_SECRET}"
          },
          "scopesConfig": {
            "default": ["openid", "profile", "email", "offline_access"],
            "available": [
              "Mail.Read",
              "Mail.Send",
              "Calendars.Read",
              "Calendars.ReadWrite",
              "Files.Read",
              "Files.ReadWrite",
              "Chat.Read",
              "Team.ReadBasic.All"
            ]
          },
          "apiDomains": ["graph.microsoft.com"]
        }
      ]
    },
    {
      "id": "notion",
      "name": "Notion",
      "description": "Workspace pages, databases, and content",
      "integrations": [
        {
          "id": "notion",
          "label": "Notion",
          "authType": "oauth",
          "oauth": {
            "authUrl": "https://api.notion.com/v1/oauth/authorize",
            "tokenUrl": "https://api.notion.com/v1/oauth/token",
            "clientId": "${env:NOTION_CLIENT_ID}",
            "clientSecret": "${env:NOTION_CLIENT_SECRET}"
          },
          "apiDomains": ["api.notion.com"]
        }
      ]
    },
