.DS_Store
node_modules

**/.claude/settings.local.json
.claude/worktrees/

# Environment files
.env
.env.*
.tmp/*
tmp/
charts/lobu/values-local.yaml

# Helm dependency files
charts/lobu/charts/
charts/lobu/Chart.lock

# Build output - compiled artifacts should not be committed
dist/
**/dist/
build/
**/build/

# TypeScript compilation artifacts in packages (but not scripts)
packages/**/*.js
packages/**/*.js.map
packages/**/*.d.ts
packages/**/*.d.ts.map

# CLI bin entrypoint is source-controlled (needed for CI publishing)
!packages/cli/bin/*.js
# Tailwind config is a JS config file, not a build artifact
!packages/gateway/tailwind.config.js
tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo

workspaces/*

# SSH keys for Terraform
charts/lobu/provider/hetzner/ssh_key
charts/lobu/provider/hetzner/ssh_key.pub
.github-app-private-key.pem
debug-voice-urls.js

# Test coverage
coverage/

# Eval results (auto-generated)
**/.results/
**/evals-report.md

# Local data (Redis, etc.)
data/
dump.rdb

# Auto-generated page CSS
packages/gateway/src/routes/public/page-styles.ts
packages/owletto-cli/runtime/

# Auto-generated history page JS bundle
packages/gateway/src/routes/public/history-page-bundle.ts
packages/gateway/src/routes/public/agent-page-bundle.ts
packages/gateway/src/routes/public/agents-page-bundle.ts
packages/gateway/src/routes/public/agents-page-bundle.raw.js

# Astro build artifacts
packages/landing/.astro/
packages/.astro/

# Pi / local agent artifacts
packages/.pi/

# Accidental clipboard artifacts
pbcopy
.pi/
packages/*/~/
