.DS_Store
node_modules

**/.claude/settings.local.json

# Environment files
.env
.env.*
.tmp/*
charts/peerbot/values-local.yaml

# Helm dependency files
charts/peerbot/charts/
charts/peerbot/Chart.lock

# Build output - compiled artifacts should not be committed
dist/
**/dist/
build/
**/build/

# TypeScript compilation artifacts in packages (but not scripts)
packages/**/*.js
packages/**/*.js.map
packages/**/*.d.ts
packages/**/*.d.ts.map
tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo

workspaces/*

# SSH keys for Terraform
charts/peerbot/provider/hetzner/ssh_key
charts/peerbot/provider/hetzner/ssh_key.pub
.github-app-private-key.pem
