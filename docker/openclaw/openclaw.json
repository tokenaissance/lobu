{
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "dev-openclaw-token"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "allowedOrigins": ["http://localhost:18789", "http://127.0.0.1:18789"]
    }
  },
  "channels": {
    "telegram": {
      "enabled": true
    }
  },
  "plugins": {
    "entries": {
      "openclaw-owletto": {
        "enabled": true,
        "config": {
          "mcpUrl": "http://app:8787/lobu/mcp/owletto",
          "webUrl": "http://app:8787",
          "gatewayAuthUrl": "http://app:8787/lobu",
          "autoRecall": true,
          "autoCapture": true
        }
      }
    },
    "installs": {
      "openclaw-owletto": {
        "source": "path",
        "sourcePath": "/plugin",
        "installPath": "/home/openclaw/.openclaw/extensions/openclaw-owletto"
      }
    },
    "slots": {
      "memory": "openclaw-owletto"
    }
  }
}
